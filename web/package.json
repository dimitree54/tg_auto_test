{
  "name": "tg-auto-test-demo-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:js": "eslint \"src/**/*.ts\" \"vite.config.ts\"",
    "fix:js": "eslint \"src/**/*.ts\" \"vite.config.ts\" --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "fix:css": "stylelint \"src/**/*.css\" --fix",
    "lint:html": "html-validate \"index.html\"",
    "lint:dups": "jscpd src --silent",
    "lint:dead": "knip",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"vite.config.ts\" \"index.html\"",
    "fix": "npm run format && npm run fix:js && npm run fix:css"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unicorn": "^56.0.1",
    "html-validate": "^8.29.0",
    "jscpd": "^4.0.8",
    "knip": "^5.85.0",
    "prettier": "^3.8.1",
    "stylelint": "^16.26.1",
    "stylelint-config-recommended": "^14.0.1",
    "stylelint-config-standard": "^36.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.1.0"
  }
}
